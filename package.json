{
  "name": "cosmetics-commerce-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "dev:api": "npm run dev --workspace @cosmetics/api",
    "dev:web": "npm run dev --workspace @cosmetics/web",
    "prisma:generate": "npm run prisma:generate --workspace @cosmetics/api",
    "prisma:migrate": "npm run prisma:migrate --workspace @cosmetics/api",
    "prisma:seed": "npm run prisma:seed --workspace @cosmetics/api"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
